# tevy2.ai — Test Config
# Copy to .env.test and fill in your keys:
#   cp .env.test.example .env.test

# Required (for both test scripts)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — omit for webchat-only mode (test-local.sh)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Test business (optional — defaults shown)
# TEST_BUSINESS_NAME=Demo Coffee Shop
# TEST_WEBSITE_URL=https://bluebottlecoffee.com
# TEST_OWNER_NAME=Test User

# Deploy test (test-deploy.sh)
# TEST_EMAIL=tevy-test@example.com
# BACKEND_URL=http://localhost:3001
