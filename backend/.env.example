# tevy2 Backend — Environment Variables

PORT=3001
INFRA_PROVIDER=hetzner

# Dev mode — skip Stytch auth, use first account in DB
DEV_BYPASS_AUTH=true

# Supabase (DB)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Hetzner Cloud
HETZNER_API_TOKEN=
HETZNER_SERVER_TYPE=cx23
HETZNER_LOCATION=nbg1
HETZNER_SNAPSHOT_ID=367242998
HETZNER_SSH_KEY_ID=109172744
HETZNER_SSH_KEY_PATH=~/.ssh/id_ed25519_hetzner
HETZNER_AGENT_DOMAIN=agents.tevy2.ai

# Stytch Auth (not needed when DEV_BYPASS_AUTH=true)
STYTCH_PROJECT_ID=
STYTCH_SECRET=

# Agent keys (shared — we pay)
ANTHROPIC_API_KEY=sk-ant-xxx
DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:3001

# Optional
TAVILY_API_KEY=

# Nango (social media OAuth — get from app.nango.dev)
NANGO_SECRET_KEY=
